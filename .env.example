APP_NAME='Occupancy Detection Service'
APP_VERSION=1.2.0

HOST=127.0.0.1
PORT=8000

USE_MOCK=true

VIDEO_SOURCE=0
MODEL_PATH=yolov8n.pt

ROI_X1=100
ROI_Y1=100
ROI_X2=500
ROI_Y2=400

ENTER_FRAMES=5
LEAVE_SECONDS=2.0
CONFIDENCE=0.4

RECONNECT_INTERVAL=2.0
LOOP_INTERVAL=0.05

MOCK_INTERVAL=1.0

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password
MYSQL_DB=your_database

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=