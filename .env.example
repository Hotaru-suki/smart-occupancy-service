APP_NAME='Occupancy Detection Service'
APP_VERSION=1.2.0

HOST=127.0.0.1
PORT=8000

USE_MOCK=true

VIDEO_SOURCE=0
MODEL_PATH=yolov8n.pt

ROI_X1=100
ROI_Y1=100
ROI_X2=500
ROI_Y2=400

ENTER_FRAMES=5
LEAVE_SECONDS=2.0
CONFIDENCE=0.4

RECONNECT_INTERVAL=2.0
LOOP_INTERVAL=0.05

MOCK_INTERVAL=1.0

# 系统启动时会确保该管理员账号存在；用户名会按后端规则转小写保存
# 本地当前示例配置：AUTH_USERNAME=admin
AUTH_USERNAME=admin
# 默认管理员密码，长度必须为 8-128；生产环境建议改用 AUTH_PASSWORD_HASH
# 本地当前示例配置：AUTH_PASSWORD=ChangeMe123!
AUTH_PASSWORD=__CHANGE_ME__
# 如果提供该值，将优先使用哈希密码而不是 AUTH_PASSWORD
AUTH_PASSWORD_HASH=
# 管理员注册必须提供该注册码；不要在公开仓库中使用真实生产值
# 本地当前示例配置：ADMIN_REGISTRATION_CODE=OccupancyAdmin2026!
ADMIN_REGISTRATION_CODE=__CHANGE_ME__
# 登录失败限制：按“来源 + 用户名”维度统计，达到阈值后进入短时锁定
# 本地当前示例配置：
# AUTH_RATE_LIMIT_WINDOW_SEC=600
# AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
# AUTH_RATE_LIMIT_LOCK_SEC=120
# 状态统计同步节流窗口，避免高频循环每次都落库
# 本地当前示例配置：STAT_SYNC_INTERVAL_SEC=5.0
AUTH_COOKIE_NAME=occupancy_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_TTL_SEC=28800
AUTH_RATE_LIMIT_WINDOW_SEC=600
AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
AUTH_RATE_LIMIT_LOCK_SEC=120
STAT_SYNC_INTERVAL_SEC=5.0

CORS_ALLOW_ORIGINS=["http://127.0.0.1:5500","http://localhost:5500","http://127.0.0.1:8000","http://localhost:8000"]

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password
MYSQL_DB=your_database

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=
